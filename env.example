# GetHiredWithAI Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Supabase Database (required)
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJyour-anon-key-here

# RapidAPI - JSearch (required for job search)
# Get from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPID_API_KEY=your-rapidapi-key-here

# Adzuna API (optional - additional job source)
# Get from: https://developer.adzuna.com
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# Gmail (optional - for email notifications)
# Enable 2FA and create App Password in Google Account
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
